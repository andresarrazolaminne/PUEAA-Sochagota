# Copiar a .env y ajustar en despliegue
DATABASE_URL="file:./data/app.db"
# Directorio para evidencias subidas (ruta absoluta o relativa al cwd del proceso)
UPLOAD_DIR="./data/uploads"
# Subruta pública (sin barra final), ej. /pueaa si Nginx sirve en https://dominio/pueaa
# Dejar vacío para desarrollo en raíz (http://localhost:3000/)
# NEXT_PUBLIC_BASE_PATH=/pueaa
